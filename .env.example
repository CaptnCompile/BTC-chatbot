# Copy to ".env" (in this directory) and fill in your Anthropic API key.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- Optional overrides (defaults shown) ------------------------------------

# Opus 4.8 is the default. `claude-sonnet-5` is a cheaper, faster drop-in and
# needs no code change — it takes the same request surface.
# ANTHROPIC_MODEL=claude-opus-4-8

# Thinking depth vs. latency: low | medium | high | xhigh | max.
# "low" keeps the chat snappy. The indicators are precomputed, so the model is
# interpreting numbers rather than deriving them. Raise for deeper reasoning.
# LLM_EFFORT=low
# LLM_MAX_TOKENS=2048

# Cache TTLs in seconds. These are what keep the app off the exchange's rate
# limits — every chat message reads through this cache, not the feed.
# PRICE_TTL_SECONDS=10
# CANDLES_TTL_SECONDS=60
# FEED_TIMEOUT_SECONDS=8

# Allowed browser origins (comma-separated). Only needed when the frontend is
# served from a different host than the API; the Vite dev proxy avoids CORS.
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
